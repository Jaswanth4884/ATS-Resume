rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Resume data: users can only read/write their own resumes
    match /resumes/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Quotation builder collections (existing)
    match /quotations/{docId} {
      allow read, write: if request.auth != null && resource == null || request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }
    match /clients/{docId} {
      allow read, write: if request.auth != null && resource == null || request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }
    match /company/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}